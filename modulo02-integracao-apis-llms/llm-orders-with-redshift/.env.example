# LLM provider switch: 'openrouter' (default) | 'litellm'
LLM_PROVIDER=litellm

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LiteLLM proxy (VTEX AI Building Block)
# Sandbox keys are per-environment; request production keys from the Admin & AI Workspace team.
LITELLM_PROXY_API_KEY=your_litellm_proxy_api_key_here
LITELLM_PROXY_API_BASE=https://ai-building-block-litellm-staging.vtex.systems
LITELLM_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# AWS / RedShift Data API
AWS_PROFILE=your_aws_sso_profile
AWS_REGION=us-east-1
REDSHIFT_CLUSTER_ID=your-cluster-id
# REDSHIFT_WORKGROUP=your-workgroup-name  # Use this instead of CLUSTER_ID for Serverless
REDSHIFT_DATABASE=your_database
REDSHIFT_DB_USER=your.email@company.com
REDSHIFT_SCHEMA=oms_silver
REDSHIFT_QUERY_TIMEOUT_MS=30000
REDSHIFT_POLL_INTERVAL_MS=800

# LangSmith (optional)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=orders-assistant-redshift
